{
  "name": "hardhat-injective-template",
  "private": true,
  "version": "0.1.0",
  "description": "Lean Hardhat starter for building and deploying EVM smart contracts on Injective Testnet.",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy": "hardhat run script/deploy.js --network inj_testnet",
