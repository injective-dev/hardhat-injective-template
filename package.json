    "interact": "hardhat console --network inj_testnet"
  },
  "keywords": [
    "hardhat",
    "injective",
    "evm",
    "starter-template",
    "smart-contracts"
  ],
  "license": "MIT",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "6.1.2",
    "dotenv": "17.4.2",
    "ethers": "6.17.0",
    "hardhat": "2.28.6"
  }
}
